# =============================================================================
# Student Management System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=student_management
DB_USER=postgres
DB_PASSWORD=postgres

# ── Database Retry (exponential backoff) ──────────────────────────────────────
DB_MAX_RETRIES=3
DB_RETRY_BASE_DELAY=100
DB_RETRY_MAX_DELAY=5000

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# 🔑 HOW TO GET A GMAIL APP PASSWORD:
#   1. Go to https://myaccount.google.com/security
#   2. Turn ON "2-Step Verification" (required)
#   3. Go back to Security > "App passwords" (under "Signing in to Google")
#   4. Select app: Mail | Select device: Other (name it "Student Management")
#   5. Click Generate — copy the 16-character code
#   6. Paste it as EMAIL_PASSWORD below (spaces are okay, include them)
#
# 💡 If you don't configure email, the app still works in development
#    mode using Ethereal (https://ethereal.email) — a fake SMTP service
#    that lets you preview emails without sending real ones.
#    In production, email must be configured or features will be disabled.

# Set to "gmail" to use Gmail's built-in SMTP config:
EMAIL_SERVICE=gmail

# Your full Gmail address:
EMAIL_USER=your-email@gmail.com

# The 16-character App Password (generated from Google Account settings):
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Note: Gmail always overrides the from address with EMAIL_USER. This setting is useful for custom SMTP.
# Optional: Override the from address
# EMAIL_FROM="Student Management" <noreply@studentmanagement.com>

# ── Email (Custom SMTP — alternative to Gmail) ──────────────────────────────
# If you're not using Gmail, uncomment and set these instead of EMAIL_SERVICE:
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-password

# ── AWS S3 (for image uploads — optional in development) ────────────────────
# In development, images are stored locally in the uploads/ directory.
# Configure AWS only if you need S3 storage in production.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=student-management-uploads
