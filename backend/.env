# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=student_management
DB_USER=postgres
DB_PASSWORD=useradmin

# Database Retry (exponential backoff)
DB_MAX_RETRIES=3
DB_RETRY_BASE_DELAY=100
DB_RETRY_MAX_DELAY=5000

# JWT
JWT_SECRET=student-management-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# AWS (optional - only needed for S3 file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=student-management-uploads

# Email (SMTP - optional, uses Ethereal in dev)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM="Student Management" <noreply@studentmanagement.com>
